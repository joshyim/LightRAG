    <node id="&quot;SCROODGE&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Ebenezer Scroodge is a miserly character who interacts with his clerk Bob Cratchit and experiences supernatural events related to Christmas Eve."</data>
      <data key="d2">chunk-d9aac3484185ac66045df92214d245d5</data>
    </node>
    <node id="&quot;MASTER PETER&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"Master Peter is a son of Bob Cratchit who plays an active role in family activities, particularly during Christmas dinner preparation."</data>
      <data key="d2">chunk-7e2e7ebcc19a53b399dc03aded4743e7</data>
    </node>
    <node id="&quot;THE TWO YOUNG CRATCHITS&quot;">
      <data key="d0">"PERSON"</data>
      <data key="d1">"The two young Cratchits are members of the family, known for their youthful energy and concern for Tiny Tim's health."</data>
      <data key="d2">chunk-503f0bfa5453467c7c61d160a3540eca</data>
    </node>
    <node id="&quot;TURKEYS, GEESE, GAME, ETC.&quot;">
      <data key="d0">"CATEGORY"</data>
