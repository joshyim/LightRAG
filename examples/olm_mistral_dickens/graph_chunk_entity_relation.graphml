      <data key="d0">"PERSON"</data>
      <data key="d1">"A child who was familiar with a simple little air played by Scrooge's niece, as remembered by Scrooge through the Ghost of Christmas Past."</data>
      <data key="d2">chunk-43c9bee23adfa77aa9dedd22401bba7d</data>
    </node>
    <node id="&quot;MOOR&quot;">
      <data key="d0">"GEO"</data>
      <data key="d1">"The moor is a bleak and desert location where miners live, visited by the Ghost of Christmas Present."</data>
      <data key="d2">chunk-91614df5cb74cbe5e109a338a82041e9</data>
    </node>
    <node id="&quot;COACH-HOUSES AND SHEDS&quot;">
      <data key="d0">"GEO"</data>
