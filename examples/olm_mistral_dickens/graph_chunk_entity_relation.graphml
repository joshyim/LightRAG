      <data key="d0">"EVENT"</data>
      <data key="d1">"The Ghost of Christmas Past shows Scrooge scenes from his life that he has long forgotten or repressed."</data>
      <data key="d2">chunk-9e3921da66da5d761ab73cd849af6c43</data>
    </node>
    <node id="&quot;BOB'S FAMILY&quot;">
      <data key="d0">"CATEGORY"</data>
      <data key="d1">"Bob Cratchit's family who Scrooge offers to assist."</data>
      <data key="d2">chunk-19fcf3bed0b4df750efc07831690f550</data>
    </node>
