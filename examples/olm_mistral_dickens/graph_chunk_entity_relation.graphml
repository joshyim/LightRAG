      <data key="d2">chunk-9e3921da66da5d761ab73cd849af6c43</data>
    </node>
    <node id="&quot;FUTURE&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Future is one of the three realms visited by Scrooge through the second spirit."</data>
      <data key="d2">chunk-cb661c37436355ccec2769b1d0350c5f</data>
    </node>
    <node id="&quot;THE UNDERTAKER'S MAN&quot;">
      <data key="d0">"PERSON"</data>
