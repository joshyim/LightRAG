      <data key="d1">"The Legacy of Choices signifies how Scrooge's past decisions shape his present and future."</data>
      <data key="d2">chunk-9c43dac2fcd5b578242d907ea6f8fc7b</data>
    </node>
    <node id="&quot;THE MOVEMENT TOWARD CHANGE&quot;">
      <data key="d0">"CONCEPT"</data>
      <data key="d1">"The Movement toward Change highlights the active process Scrooge participates in to reshape his identity."</data>
      <data key="d2">chunk-9c43dac2fcd5b578242d907ea6f8fc7b</data>
    </node>
    <node id="&quot;THE DAWNING OF AWARENESS&quot;">
