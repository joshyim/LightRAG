      <data key="d1">"The Twelfth-Night party is a social gathering that represents joy and celebration, contrasting with the heavier themes of the narrative."</data>
      <data key="d2">chunk-e7637ff18c5ded77a68cce0a87883fad</data>
    </node>
    <node id="&quot;THE BED&quot;">
