      <data key="d2">chunk-9c43dac2fcd5b578242d907ea6f8fc7b</data>
    </node>
    <node id="&quot;THE CHOIR OF SPIRITS&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Choir of Spirits signifies the harmonization of voices in Scrooge’s life urging him toward a moral reckoning."</data>
      <data key="d2">chunk-9c43dac2fcd5b578242d907ea6f8fc7b</data>
    </node>
    <node id="&quot;THE HARVEST OF CHANGE&quot;">
