      <data key="d1">"The Reawakening of the Soul signifies the revitalization of Scrooge's inner life as he embraces new truths."</data>
      <data key="d2">chunk-9c43dac2fcd5b578242d907ea6f8fc7b</data>
    </node>
    <node id="&quot;CHARITY&quot;">
      <data key="d0">"CONCEPT"</data>
