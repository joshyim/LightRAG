      <data key="d2">chunk-1d4b58de5429cd1261370c231c8673e8</data>
    </node>
    <node id="&quot;GHOST OF CHRISTMAS PRESENT&quot;">
      <data key="d0">"EVENT"</data>
      <data key="d1">"The Ghost of Christmas Present is a spirit that reveals to Scrooge the current realities of those around him, encouraging empathy."&lt;SEP&gt;"The Ghost of Christmas Present is a spirit that visits Scrooge to impart lessons about generosity and the present moment."&lt;SEP&gt;"The Ghost of Christmas Present represents a supernatural embodiment of festive joy and a guide to Scrooge's transformation during Christmas."</data>
      <data key="d2">chunk-843b5b2f944c7413d9ca876e2e2f151f&lt;SEP&gt;chunk-43c9bee23adfa77aa9dedd22401bba7d&lt;SEP&gt;chunk-9e3921da66da5d761ab73cd849af6c43</data>
    </node>
    <node id="&quot;CHRISTMAS EVES&quot;">
      <data key="d0">"EVENT"</data>
