      <data key="d1">"The Deep Connection represents the bonds Scrooge begins to form as he opens his heart to others."</data>
      <data key="d2">chunk-9c43dac2fcd5b578242d907ea6f8fc7b</data>
    </node>
    <node id="&quot;THE ZEST FOR LIFE&quot;">
